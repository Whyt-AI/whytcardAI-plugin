{
  "name": "whytcardAI-plugin",
  "version": "1.0.0",
  "description": "WhytCard AI agent constitution — enforces research-first, proof-driven, UX-obsessed development through hooks, skills, and routing rules",
  "author": "Whyt-AI",
  "repository": "https://github.com/Whyt-AI/whytcardAI-plugin",
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "node hooks/session-start.js"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node hooks/pre-edit-gate.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node hooks/stop-verify.js"
          }
        ]
      }
    ]
  },
  "skills": [
    "skills/dispatch/SKILL.md",
    "skills/visual-verify/SKILL.md",
    "skills/research-first/SKILL.md",
    "skills/version-check/SKILL.md"
  ],
  "agents": [
    "agents/quality-gate/AGENT.md"
  ]
}
